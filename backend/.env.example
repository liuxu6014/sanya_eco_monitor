# =================================================================
# 三亚生态监测系统 - 后端环境变量配置模版
# 复制此文件为 .env 并填写实际配置
# =================================================================

# --- 1. 物联网平台采集配置 (智慧农业平台) ---
PLATFORM_BASE_URL=https://zhnlkj.com/iotSmasrt
PLATFORM_USERNAME=zhnl
PLATFORM_PASSWORD=123456

# 特定设备标识码 (用于 API 筛选)
INSECT_CODE=202603172301
SPORE_CODE=202603172302
INSECT_LOOKBACK_HOURS=168
SPORE_LOOKBACK_HOURS=168
WEATHER_CODE=16110669
SOIL_CODE=16110670
PREVENTION_CODE=864249073501866
SEEDLING_CODE=FM9400487

# --- 2. WHXPH 平台配置 (监测降雨、流量等) ---
# 该平台提供免 token 的最新数据接口
WHXPH_BASE_URL=https://iot.whxph.com:44300/XPHapiv2
RAIN_GAUGE_ID=
FLOW_METER_ID=
LEVEL_GAUGE_ID=
RUNOFF_CODES=16132920,16132921,16132922,16132923,16132924,16132925
RAIN_GAUGE_CODES=

# --- 3. 系统运行参数 ---
COLLECT_INTERVAL_MINUTES=30
DEBUG=false

# --- 3.1 平台访问鉴权 ---
# 进入平台时需要输入的访问密码，请务必修改
ACCESS_PASSWORD=change-this-password
AUTH_COOKIE_NAME=sanya_monitor_auth
AUTH_MAX_AGE_HOURS=12

# --- 4. AI 报告生成配置 (大模型 API) ---
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# 图像生成 (用于报告插图)
IMAGE_GEN_BASE_URL=https://yinli.one
IMAGE_GEN_API_KEY=
IMAGE_GEN_MODEL=gemini-2.5-flash-image
